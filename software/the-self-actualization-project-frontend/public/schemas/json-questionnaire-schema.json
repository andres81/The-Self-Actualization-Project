{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.the-self-actualization-project.com/schemas/json-questionnaire-schema.json",
  "title": "JSON Questionnaire Schema",
  "description": "A JSON Questionnaire Schema",
  "type": "object",
  "properties": {
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "cardinality": {
            "type": "string"
          },
          "prompt": {
            "type": "string"
          },
          "maxChoices": {
            "type": "integer",
            "minimum": 1
          },
          "correctResponses": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "options": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "identifier": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                }
              },
              "required": [
                "identifier",
                "label"
              ]
            },
            "minItems": 2
          }
        },
        "required": [
          "id",
          "cardinality",
          "prompt",
          "maxChoices",
          "correctResponses",
          "options"
        ]
      }
    }
  }
}