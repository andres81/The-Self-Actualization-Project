{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.andreschepers.nl/schemas/json-questionnaire-schema.json",
  "title": "JSON Questionnaire Schema",
  "description": "A JSON Questionnaire Schema",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "properties": {
      "json-choice-interaction-item": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "cardinality": {
            "type": "string"
          },
          "question": {
            "type": "string"
          },
          "max-choices": {
            "type": "integer",
            "minimum": 1
          },
          "correct-responses": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "options": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "identifier": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                }
              },
              "required": [
                "identifier",
                "label"
              ]
            },
            "minItems": 2
          }
        },
        "required": [
          "id",
          "cardinality",
          "question",
          "max-choices",
          "correct-responses",
          "options"
        ]
      }
    },
    "required": [
      "json-choice-interaction-item"
    ]
  }
}
